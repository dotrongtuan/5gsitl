PROJECT_NAME=5g-nr-sitl-omnetpp-testbed
PROJECT_ROOT=$PWD
OPEN5GS_CONFIG_DIR=$PWD/configs/core
OPEN5GS_LOG_DIR=$PWD/outputs/logs/open5gs
OPEN5GS_PID_DIR=$PWD/outputs/runtime/pids
# Minimal working SA attach baseline for the current compat path:
# - AMF: amf_compat.yaml
# - SMF: smf_compat.yaml
# - PCF: enabled and backed by MongoDB
# - NSSF: disabled
OPEN5GS_SUBSCRIBERS_FILE=$PWD/configs/core/subscribers_compat.yaml
OPEN5GS_AMF_CONFIG=$PWD/configs/core/amf_compat.yaml
OPEN5GS_SMF_CONFIG=$PWD/configs/core/smf_compat.yaml
OPEN5GS_ENABLE_PCF=1
OPEN5GS_ENABLE_NSSF=0
MONGODB_URI=mongodb://127.0.0.1/open5gs
SRSRAN_GNB_BIN=gnb
SRSRAN_UE_BIN=srsue
# Direct-ZMQ attach baseline:
# - gNB: gnb_zmq_compat.yaml
# - UE:  ue_zmq_compat.conf
# - Channel: bypass_compat.yaml reports direct-zmq mode
SRSRAN_GNB_CONFIG=$PWD/configs/gnb/gnb_zmq_compat.yaml
SRSRAN_UE_CONFIG=$PWD/configs/ue/ue_zmq_compat.conf
OMNETPP_ROOT=$HOME/opt/omnetpp-6.0.3
OMNETPP_INI=$PWD/omnetpp/simulations/omnetpp.ini
GNURADIO_CHANNEL_PROFILE=$PWD/configs/channel/bypass_compat.yaml
NR_PROFILE=$PWD/configs/nr_profiles/bootstrap_compat_mu0_15k.yaml
SLICE_PROFILE=$PWD/configs/slicing/embb.yaml
ZMQ_LINKS=$PWD/configs/zmq/links.yaml
STATE_FILE=$PWD/outputs/runtime/state.json
STATE_ENV_FILE=$PWD/outputs/runtime/omnetpp.env
EVENT_LOG=$PWD/outputs/runtime/events.jsonl
METRICS_FILE=$PWD/outputs/runtime/metrics.json
CAPTURE_DIR=$PWD/outputs/pcap
REPORT_DIR=$PWD/outputs/reports
CSV_DIR=$PWD/outputs/csv
FIGURE_DIR=$PWD/outputs/figures
LOG_DIR=$PWD/outputs/logs
UE_NAMESPACE=ue1
UE_TUN=uesimtun0
CORE_BIND_ADDR=127.0.0.1
N2_BIND_ADDR=10.10.0.10
N3_BIND_ADDR=10.20.0.1
UPF_N6_IF=ogstun
UE_DNN=internet
UE_IP_POOL=10.45.0.0/16
GNB_MCC=001
GNB_MNC=01
GNB_TAC=7
GNB_PCI=1
NR_MU=0
NR_SCS_KHZ=15
NR_SLOT_MS=1.0
BOOTSTRAP_PROFILE=compat
AUTO_START_STACK=1
AUTO_RUN_HEALTHCHECK=1
ADAPTER_HTTP_HOST=127.0.0.1
ADAPTER_HTTP_PORT=18080
CAPTURE_SNAPLEN=0
CAPTURE_ROTATE_MB=250
CAPTURE_ROTATE_COUNT=8
